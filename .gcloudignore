# Allow-list: only paths the Dockerfile actually needs.
# Build context = repo root; Dockerfile lives at backend/Dockerfile.

# Default: exclude everything at the repo root...
*

# ...then re-include only what's needed for the image build.
!backend/
!dataconnect/
!cloudbuild.yaml

# Inside the allowed dirs, still skip noise that shouldn't be uploaded.
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.py[cod]
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/
backend/tests/
backend/*.log

# Local secrets — never ship into a build artifact.
backend/.env
backend/.env.*
!backend/.env.example

# Editor / OS cruft inside allowed dirs.
**/.DS_Store
**/.vscode/
**/.idea/
