# Herofy Python Backend Environment Variables

# Database (same as Express API)
DATABASE_URL=postgresql://herofy:herofy_local@localhost:5432/herofy_dev

# Google AI
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_CLOUD_PROJECT=your-project-id

# Server
PORT=8081
LOG_LEVEL=INFO

# Notion MCP (optional - mock mode if not set)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Environment
ENVIRONMENT=development

# Metric Snapshots — time-series substrate (docs/plans/SIGNAL_AGGREGATION.md).
# When false (default) all snapshot writes are no-ops and the backend behaves
# exactly as today. Flip to true + restart to begin appending health/vector/
# engagement history to the MetricSnapshot table.
METRIC_SNAPSHOTS_ENABLED=false

# Firestore Emulator (required for real-time UI updates in development)
# Must be set BEFORE starting the backend for Firestore writes to go to emulator
FIRESTORE_EMULATOR_HOST=localhost:8181
